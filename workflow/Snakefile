# Main entrypoint of the workflow.
# Please follow the best practices:
# https://snakemake.readthedocs.io/en/stable/snakefiles/best_practices.html,
# in particular regarding the standardized folder structure mentioned there.

import os
import sys
import pprint
import shutil
import subprocess

from snakemake.utils import validate
from snakemake.utils import min_version

min_version("9.0.0")

validate(config, "config.schema.yaml")
print("Config loaded:\n{}".format(config), file=sys.stderr)

MANIFEST = {}
VALID_PLATFORMS = {"pacbio", "ont", "illumina"}

with open(config["manifest"]) as fh:
    header = None
    for raw_line in fh:
        line = raw_line.rstrip("\n")
        if not line or line.startswith("#"):
            continue
        tokens = line.split("\t")
        if header is None:
            header = [c.strip() for c in tokens]
            required = {"sample", "dsa", "bam", "h1_tag", "h2_tag", "platform", "fiber-seq"}
            missing = required - set(header)
            if missing:
                raise ValueError(
                    f"Manifest {config['manifest']} missing required columns: {sorted(missing)}"
                )
            continue
        if len(tokens) != len(header):
            raise ValueError(
                f"Manifest row has {len(tokens)} fields, expected {len(header)}: {line!r}"
            )
        row = dict(zip(header, [t.strip() for t in tokens]))

        sm_id = row["sample"]
        plat = row["platform"].lower()
        if plat not in VALID_PLATFORMS:
            raise ValueError(
                f"Sample {sm_id}: unknown platform {plat!r}; "
                f"must be one of {sorted(VALID_PLATFORMS)}"
            )

        fs_raw = row["fiber-seq"].lower()
        if fs_raw not in {"true", "false"}:
            raise ValueError(
                f"Sample {sm_id}: fiber-seq must be 'true' or 'false', got {fs_raw!r}"
            )
        fiber_seq = fs_raw == "true"

        if plat == "illumina" and fiber_seq:
            raise ValueError(
                f"Sample {sm_id}: illumina + fiber-seq=true is not supported"
            )

        h1_tag = row["h1_tag"] if row["h1_tag"] != "NA" else "h1"
        h2_tag = row["h2_tag"] if row["h2_tag"] != "NA" else "h2"
        bam_files = [b.strip() for b in row["bam"].split(",")]

        if sm_id not in MANIFEST:
            MANIFEST[sm_id] = {
                "dsa": row["dsa"],
                "bam": bam_files,
                "h1_tag": h1_tag,
                "h2_tag": h2_tag,
                "platform": plat,
                "fiber-seq": fiber_seq,
            }
        else:
            # Same sample on multiple rows: extend BAM list, require consistent metadata.
            existing = MANIFEST[sm_id]
            for key, new_val in (
                ("dsa", row["dsa"]),
                ("h1_tag", h1_tag),
                ("h2_tag", h2_tag),
                ("platform", plat),
                ("fiber-seq", fiber_seq),
            ):
                if existing[key] != new_val:
                    raise ValueError(
                        f"Sample {sm_id}: conflicting {key!r} across rows "
                        f"({existing[key]!r} vs {new_val!r})"
                    )
            existing["bam"].extend(bam_files)


def has_fiberseq_pg(bam_path):
    """True iff a @PG header line was written by fibertools-rs (ft predict-m6a).

    This is the PacBio Fiber-seq fingerprint: genuine Fiber-seq HiFi data is
    m6A-called by `ft predict-m6a`, which stamps a `PN:fibertools-rs` @PG line.
    Reads only the header (no reference needed).
    """
    header = subprocess.run(
        ["samtools", "view", "-H", bam_path],
        check=True,
        capture_output=True,
        text=True,
    ).stdout
    return any(
        line.startswith("@PG") and "PN:fibertools-rs" in line
        for line in header.splitlines()
    )


# Sanity check: PacBio samples marked fiber-seq=true must carry the fibertools-rs
# @PG signature in every input BAM/CRAM. (ONT Fiber-seq inputs get their m6A from
# modkit inside the workflow, so they are not checked here.)
_pb_fs_samples = [
    sm
    for sm in MANIFEST
    if MANIFEST[sm]["platform"] == "pacbio" and MANIFEST[sm]["fiber-seq"]
]
if _pb_fs_samples and shutil.which("samtools") is None:
    raise ValueError(
        "samtools not found on PATH; it is required at load time to validate "
        "PacBio Fiber-seq inputs (fiber-seq=true)."
    )
for _sm in _pb_fs_samples:
    for _bam in MANIFEST[_sm]["bam"]:
        if not has_fiberseq_pg(_bam):
            raise ValueError(
                f"Sample {_sm}: fiber-seq=true (pacbio) but input {_bam!r} has no "
                f"fibertools-rs @PG line (expected from `ft predict-m6a`). "
                f"If this is not Fiber-seq data, set fiber-seq=false in the manifest."
            )

SHARED_REF = config.get("shared_reference", list())

print("Manifest loaded with {} samples.".format(len(MANIFEST)), file=sys.stderr)
# pprint.pprint(MANIFEST, depth=3, stream=sys.stderr)


MAX_THREADS = config.get("max_threads", 64)
DEFAULT_ENV = "../envs/env.yml"

SMs = list(MANIFEST.keys())


wildcard_constraints:
    sm="|".join(SMs),
    file_idx=r"\d+",


include: "rules/common.smk"
include: "rules/dsa-phase.smk"


# Build the list of needed outputs by dispatching on each sample's platform/fiber-seq.
needed_outputs = []
for sm in SMs:
    needed_outputs.append(final_cram_name(sm))
    if MANIFEST[sm]["fiber-seq"]:
        needed_outputs.append(f"results/{sm}.qc.tbl.gz")
    elif MANIFEST[sm]["platform"] == "illumina":
        needed_outputs.append(f"results/{sm}.flagstat.txt")

# Realign to shared reference if provided.
if len(SHARED_REF) > 0:
    print(f"Realigning to shared reference: {SHARED_REF}", file=sys.stderr)
    for sm in SMs:
        needed_outputs.append(f"results/{sm}.shared.ref.cram")


rule all:
    input:
        needed_outputs,
